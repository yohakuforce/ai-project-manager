# ============================================================
# AI-Project-Manager 環境変数テンプレート
# 実際の .env は社内 PC のみに置く。このファイルはリポジトリに含める。
# ============================================================

# --- アプリケーション設定 ---
APP_ENV=development                    # development | production
APP_SECRET_KEY=change-me-to-random-secret
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# --- DB (社内 PC の PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_project_manager
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@${DB_HOST}/${DB_NAME}

# --- LLM プロバイダ設定 ---
LLM_PROVIDER=claude                    # claude | antigravity | codex
ANTHROPIC_API_KEY=sk-ant-...           # Claude API キー（claude 使用時）
OPENAI_API_KEY=sk-...                  # OpenAI API キー（codex / embedding 使用時）
AZURE_OPENAI_ENDPOINT=                 # Azure OpenAI エンドポイント（Azure 使用時）
AZURE_OPENAI_API_KEY=                  # Azure OpenAI API キー（Azure 使用時）
AZURE_OPENAI_DEPLOYMENT=               # Azure OpenAI デプロイ名（Azure 使用時）

# --- Context-Hub 接続設定 ---
CONTEXT_HUB_BASE_URL=http://localhost:8000/api/v1
CONTEXT_HUB_API_KEY=ctx-hub-aipm-change-me
CONTEXT_HUB_USE_MOCK=true             # true = モック使用（Context-Hub 本体なし）

# --- Slack 通知設定 ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_NOTIFICATION_CHANNEL=#ai-pm-alerts   # アラート通知先チャンネル

# --- スケジューラ設定 ---
DAILY_REPORT_DELIVERY_HOUR=8          # 日報配信時刻（24h、現地時間）
DAILY_OVERVIEW_GENERATION_HOUR=7      # 朝サマリ生成時刻
ALERT_SCAN_INTERVAL_MINUTES=30        # アラートスキャン間隔

# --- セキュリティ設定 ---
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_HOURS=8

# --- 監査ログ設定 ---
AUDIT_LOG_RETENTION_DAYS=365
