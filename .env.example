# ============================================================
# AI-Project-Manager 環境変数テンプレート
# 実際の .env は社内 PC のみに置く。このファイルはリポジトリに含める。
# ============================================================

# --- アプリケーション設定 ---
APP_ENV=development                    # development | production
APP_SECRET_KEY=change-me-to-random-secret
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# --- DB (社内 PC の PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_project_manager
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@${DB_HOST}/${DB_NAME}
USE_DATABASE=true                      # true=PostgreSQL 永続化（ゲート等）, false=インメモリ(dev/テスト)

# --- LLM プロバイダ設定 ---
# 既定は claude-code（サブスクリプション範囲で動作・API 課金なし）。いずれも課金 API ではない。
#   claude-code : Claude Code CLI（subprocess）。サブスク AI。推奨。
#   codex       : Codex CLI（`codex -q`）。サブスク AI。
#   antigravity : Antigravity CLI。サブスク AI。
#   local       : OpenAI 互換ローカル LLM（Ollama/LM Studio/vLLM/llama.cpp 等。Ollama 非限定）。
#   ollama      : ローカル Ollama native API（/api/generate）。完全オフライン。
#   mock        : テスト用モック（決定性・LLM 呼び出しなし）。
#   claude      : Anthropic API 直接呼び出し（課金 API）。非推奨・本番禁止。
LLM_PROVIDER=claude-code               # claude-code | codex | antigravity | local | ollama | mock
# ANTHROPIC_API_KEY=sk-ant-...         # 非推奨 LLM_PROVIDER=claude を使う場合のみ必要。通常は不要。

# CLI 系（サブスク）— パス空なら PATH から自動検出。タイムアウトは秒。
# CODEX_CLI_PATH=
# CODEX_TIMEOUT_SECONDS=120
# ANTIGRAVITY_CLI_PATH=
# ANTIGRAVITY_PROMPT_FLAG=-p            # Antigravity CLI 仕様に合わせて調整
# ANTIGRAVITY_TIMEOUT_SECONDS=120

# ローカル LLM（LLM_PROVIDER=local。OpenAI 互換 /v1/chat/completions を叩く）
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama=:11434/v1, LM Studio=:1234/v1 等
# LOCAL_LLM_MODEL=llama3
# LOCAL_LLM_API_KEY=                    # 鍵を要求するサーバ向け（通常は空）
# LOCAL_LLM_TIMEOUT_SECONDS=180

# Ollama native（LLM_PROVIDER=ollama）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_TIMEOUT_SECONDS=180

# --- Context-Hub 接続設定 ---
CONTEXT_HUB_BASE_URL=http://localhost:8000/api/v1
CONTEXT_HUB_API_KEY=ctx-hub-aipm-change-me
CONTEXT_HUB_USE_MOCK=true             # true = モック使用（Context-Hub 本体なし）

# --- Slack 通知設定 ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_NOTIFICATION_CHANNEL=#ai-pm-alerts   # アラート通知先チャンネル

# --- スケジューラ設定 ---
# 各フェーズの時刻（時・分）は自由に調整可。実行順序は常に固定
# （standup→report_generate→report_deliver→report_reminder→wrap_up→alert_scan）。
# final_analysis はリーダー確認ゲート駆動のため cron には載らない。
SCHEDULER_ENABLED=true                  # 自動スケジューラの有効/無効
SCHEDULER_TIMEZONE=Asia/Tokyo          # cron 時刻の解釈に使うタイムゾーン
STANDUP_HOUR=9                         # 朝会（スタンドアップ）時
STANDUP_MINUTE=0                       # 朝会 分
REPORT_HOUR=14                         # 日報生成→配信 時
REPORT_MINUTE=0                        # 日報 分
REMINDER_HOUR=17                       # 日報未提出の催促 時
REMINDER_MINUTE=0                      # 催促 分
WRAP_UP_HOUR=17                        # 当日総括＋確認ゲート 時
WRAP_UP_MINUTE=30                      # 総括 分
ALERT_SCAN_INTERVAL_MINUTES=30         # アラートスキャン間隔（分）

# --- セキュリティ設定 ---
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_HOURS=8

# --- 監査ログ設定 ---
AUDIT_LOG_RETENTION_DAYS=365
